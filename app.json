{
  "expo": {
    "name": "BibleApp",
    "slug": "BibleApp",
    "owner": "dicipleofjx2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bibleapp",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#1E3350",
    "ios": {
      "bundleIdentifier": "com.dicipleofjx2.bibleapp",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.dicipleofjx2.bibleapp",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#1E3350",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1E3350",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3894a5ec-b573-429b-a871-3c96e7a89a0b"
      }
    }
  }
}
